# ============================================================
# CrimeVision AI — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in your actual credentials.
# .env is gitignored. .env.example is safe to commit.
# ============================================================

# -- QuickML OAuth2 Credentials ------------------------------
# Steps to obtain:
# 1. Go to https://api-console.zoho.in
# 2. Create a Self Client or Server-based OAuth app
# 3. Scopes: QuickML.deployment.READ, ZohoCatalyst.projects.ALL
# 4. Generate a Refresh Token using the Authorization Code flow
# 5. Paste the values below

QUICKML_CLIENT_ID=
QUICKML_CLIENT_SECRET=
QUICKML_REFRESH_TOKEN=

# -- QuickML RAG Endpoint -------------------------------------
# Format: https://api.catalyst.zoho.in/quickml/v1/project/<PROJECT_ID>/rag/answer
# Your project ID is: 50276000000016025

QUICKML_ENDPOINT_URL=https://api.catalyst.zoho.in/quickml/v1/project/50276000000016025/rag/answer

# -- Catalyst Organization ------------------------------------
# Found in .catalystrc: "id": "60074947232"

CATALYST_ORG_ID=60074947232

# -- Catalyst File Store Folder ID ----------------------------
# The ID of the folder named 'datasets' created inside Catalyst File Store
CATALYST_DATASETS_FOLDER_ID=
